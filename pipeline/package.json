{
  "name": "@budget-france/pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "Pipeline d'ingestion multi-sources pour le budget de l'État français",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:mock": "tsx src/ingest.ts --mock",
    "watch": "tsx watch src/ingest.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}

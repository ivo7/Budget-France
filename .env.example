# ========================================================================
# Budget France — Variables d'environnement
# Copie ce fichier en `.env` à la racine du projet et renseigne les valeurs.
# Docker Compose lira automatiquement `.env`.
# ========================================================================

# ---- PostgreSQL ----
# Mot de passe à changer en prod. Laisse tel quel en local.
POSTGRES_USER=budget
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=budget

# ---- URL publique ----
# En local :  http://localhost:4280
# En prod   :  https://budgetfrance.fr
PUBLIC_BASE_URL=http://localhost:4280

# ---- Email ----
# Expéditeur affiché. Doit matcher un domaine vérifié chez ton provider SMTP.
EMAIL_FROM=Budget France <notifications@budgetfrance.fr>
EMAIL_REPLY_TO=contact@budgetfrance.fr

# --- Choisis UN provider SMTP et décommente le bloc correspondant ---

# --- Option 1 : Resend (Recommandé — 3 000 emails/mois gratuits)
#     Inscris-toi sur https://resend.com, vérifie ton domaine, crée une clé API.
#SMTP_HOST=smtp.resend.com
#SMTP_PORT=587
#SMTP_USER=resend
#SMTP_PASS=re_XXXXXXXXXXXXXXXXX   # ta clé API Resend

# --- Option 2 : Brevo (ex-Sendinblue — 9 000 emails/mois gratuits)
#SMTP_HOST=smtp-relay.brevo.com
#SMTP_PORT=587
#SMTP_USER=ton-email-brevo@example.com
#SMTP_PASS=xxxxxxxxxxxxxxxx

# --- Option 3 : Mailjet (6 000 emails/mois gratuits)
#SMTP_HOST=in-v3.mailjet.com
#SMTP_PORT=587
#SMTP_USER=<api_key>
#SMTP_PASS=<secret_key>

# --- Option 4 : Gmail (réservé aux tests — limité, requiert un mot de passe d'application)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=ton.email@gmail.com
#SMTP_PASS=xxxxxxxxxxxxxxxx

# ---- Mode dev (sans SMTP) ----
# Laisse TOUS les SMTP_* vides pour que les emails soient loggués en console
# au lieu d'être envoyés. Pratique pour tester sans provider.

# ---- Seuils d'alerte ----
# Dette : delta absolu (en euros) entre 2 snapshots pour déclencher une alerte.
# Défaut : 50 Md€
THRESHOLD_DETTE_EUR=50000000000

# OAT : delta en points de base (1 pb = 0,01 pt). Défaut : 20 pb (= 0,20 pt)
THRESHOLD_OAT_BP=20

# ---- Webhooks sortants (optionnel) ----
# À chaque alerte de seuil franchi, le backend peut pousser l'événement vers
# un ou plusieurs webhooks externes. Ajoute l'URL du webhook de la plateforme
# que tu veux utiliser.

# Slack : créer un incoming webhook dans un canal
# https://api.slack.com/messaging/webhooks
#SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXX/BXXXX/XXXX

# Discord : paramètres d'un canal → Intégrations → Webhooks → Nouveau webhook
#DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/XXXX/XXXX

# Webhook générique (n'importe quel endpoint qui accepte POST JSON)
#GENERIC_WEBHOOK_URL=https://ton-serveur.fr/budget-france/alerts

# ---- API publique ----
# Clé admin optionnelle : détenteurs bénéficient d'un rate-limit plus élevé
# (300 req/min au lieu de 30). Laisse vide pour désactiver.
# Usage : envoyer le header X-API-Key dans les requêtes.
#API_ADMIN_KEY=change-me-in-prod
